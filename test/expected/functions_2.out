-- encode(bytea, 'base64') pushes down as base64Encode wrapped to reproduce
-- PG's MIME (RFC 2045) line break every 76 characters.
EXPLAIN (VERBOSE, COSTS OFF)
SELECT encode(val::bytea, 'base64') AS b FROM t4 GROUP BY b ORDER BY b;
                                                                                                                                                                                                        QUERY PLAN                                                                                                                                                                                                        
--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 Foreign Scan
   Output: (encode((val)::bytea, 'base64'::text))
   Relations: Aggregate on (t4)
   Remote SQL: SELECT replaceRegexpAll(replaceRegexpAll(base64Encode(CAST(val AS bytea(0))), '(.{76})', '\\1\n'), '(=+)\n$', '\\1') FROM functions_test.t4 GROUP BY (replaceRegexpAll(replaceRegexpAll(base64Encode(CAST(val AS bytea(0))), '(.{76})', '\\1\n'), '(=+)\n$', '\\1')) ORDER BY replaceRegexpAll(replaceRegexpAll(base64Encode(CAST(val AS bytea(0))), '(.{76})', '\\1\n'), '(=+)\n$', '\\1') ASC NULLS LAST
(4 rows)

SELECT encode(val::bytea, 'base64') AS b FROM t4 GROUP BY b ORDER BY b;
