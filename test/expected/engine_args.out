CREATE SERVER engine_args_svr FOREIGN DATA WRAPPER clickhouse_fdw
    OPTIONS(dbname 'engine_args_test', driver 'binary');
CREATE USER MAPPING FOR CURRENT_USER SERVER engine_args_svr;
